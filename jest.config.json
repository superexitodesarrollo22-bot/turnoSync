{
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
        "<rootDir>/supabase/functions/__tests__"
    ],
    "testMatch": [
        "**/*.test.ts"
    ],
    "transform": {
        "^.+\\.tsx?$": [
            "ts-jest",
            {
                "tsconfig": {
                    "module": "commonjs",
                    "esModuleInterop": true,
                    "allowSyntheticDefaultImports": true
                }
            }
        ]
    },
    "moduleNameMapper": {
        "^https://deno.land/.*$": "<rootDir>/supabase/functions/__mocks__/deno.ts",
        "^https://esm.sh/.*$": "<rootDir>/supabase/functions/__mocks__/esm.ts"
    }
}