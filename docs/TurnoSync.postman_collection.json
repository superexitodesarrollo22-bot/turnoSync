{
    "info": {
        "name": "TurnoSync API",
        "description": "Supabase Edge Functions — TurnoSync",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "SUPABASE_URL",
            "value": "https://YOUR_PROJECT.supabase.co"
        },
        {
            "key": "ANON_KEY",
            "value": "YOUR_ANON_KEY"
        },
        {
            "key": "JWT_TOKEN",
            "value": "YOUR_USER_JWT"
        },
        {
            "key": "BUSINESS_ID",
            "value": "b0000000-0000-0000-0000-000000000001"
        },
        {
            "key": "SERVICE_ID",
            "value": ""
        },
        {
            "key": "APPOINTMENT_ID",
            "value": ""
        }
    ],
    "item": [
