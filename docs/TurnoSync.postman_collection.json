            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{JWT_TOKEN}}"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "url": "{{SUPABASE_URL}}/functions/v1/create_appointment",
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"business_id\": \"{{BUSINESS_ID}}\",\n  \"service_id\": \"{{SERVICE_ID}}\",\n  \"requested_start_at\": \"2026-03-10T14:00:00.000Z\"\n}"
                }
            }
        },
